#pragma once

// Copy this file to include/secrets.h and fill in your credentials.
// include/secrets.h is gitignored — never commit real credentials.

#define WIFI_SSID          "your-wifi-ssid"
#define WIFI_PASSWORD      "your-wifi-password"
// Fallback only: the controller first tries to resolve the Bitaxe via mDNS
// (bitaxe.local) at startup and on every WiFi reconnect, and only falls
// back to this address if that fails (#7).
#define BITAXE_IP          "192.168.0.100"
#define TELEGRAM_BOT_TOKEN "123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#define TELEGRAM_CHAT_ID   "123456789"
#define DEEPSEEK_API_KEY   "sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
// Required by the OTA receiver (#10). espota reads it from this file
// automatically when flashing over WiFi (see ota_auth.py) — pick any
// non-empty string; it only needs to match between device and uploader.
#define OTA_PASSWORD       "your-ota-password"

// Optional: any OpenAI-compatible chat completions endpoint (DeepSeek default)
// #define AI_BASE_URL "https://api.deepseek.com/v1/chat/completions"
// #define AI_MODEL    "deepseek-chat"

// SECURITY WARNING (#76): the default DeepSeek endpoint (and Telegram) have
// their root CAs pinned in the firmware, but a custom AI_BASE_URL host gets
// NO TLS certificate validation — your API key would travel over an
// unverified connection, open to MITM on path. To fix that, pin your
// endpoint's root CA here (PEM, e.g. from
// `openssl s_client -showcerts -connect your-host:443`):
// #define AI_ROOT_CA R"CERT(
// -----BEGIN CERTIFICATE-----
// ...your endpoint's ROOT certificate...
// -----END CERTIFICATE-----
// )CERT"
